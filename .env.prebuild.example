# Optional prebuild settings. Copy the values you need into .env only when you
# want to bake known Dart targets into a custom image.

# Example image tag for a prebuilt image.
BLUTTER_IMAGE=blutter:prebuilt

# One or more targets in VERSION or VERSION_OS_ARCH format.
# Examples:
# PREBUILD_TARGETS=3.24.0
# PREBUILD_TARGETS=3.24.0,3.27.2
# PREBUILD_TARGETS=3.24.0_android_arm64
PREBUILD_TARGETS=

# Optional: also prebuild the --no-analysis binary.
PREBUILD_WITH_NO_ANALYSIS=0

# Optional: set to 0 for targets that use non-compressed pointers.
PREBUILD_COMPRESSED_PTRS=1
